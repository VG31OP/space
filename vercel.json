    {
      "source": "/api/news/:path*",
      "destination": "https://newsapi.org/:path*"
    },
    {
      "source": "/api/firms/:path*",
      "destination": "https://firms.modaps.eosdis.nasa.gov/:path*"
    }
  ]
}

